   "source": [
    "# Factorial of a Number"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "df23f353",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Factorin is:  6\n"
     ]
    }
   ],
   "source": [
    "num = int(input(\"Enter Your Number: \"))\n",
    "result =1\n",
    "\n",
    "for i in range(1, num+1):\n",
    "    result = result * i\n",
    " \n",
    "print(\"Factorin is: \", result)"
   ]
  }
